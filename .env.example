# 学术报告生成Agent - 环境变量配置示例
# 复制此文件为 .env 并填入你的配置
# 注意：.env 文件不应提交到Git仓库（已在.gitignore中）

# ========== 平台选择 ==========
# 选择使用哪个平台：coze 或 volcengine
# coze: Coze平台（默认）
# volcengine: 火山引擎豆包API
PLATFORM=coze

# ========== Coze平台配置（如果PLATFORM=coze）==========
# COZE工作负载身份API密钥
# 获取方式：登录COZE平台 -> API密钥管理 -> 创建新密钥
COZE_WORKLOAD_IDENTITY_API_KEY=your_coze_api_key_here

# COZE集成模型基础URL
# 通常不需要修改，保持默认即可
COZE_INTEGRATION_MODEL_BASE_URL=https://api.coze.cn

# ========== 火山引擎豆包API配置（如果PLATFORM=volcengine）==========
# 火山引擎API密钥
# 获取方式：登录火山引擎方舟 -> API密钥管理
VOLCENGINE_API_KEY=your_volcengine_api_key_here

# 火山引擎API基础URL
# 通常不需要修改
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 火山引擎模型ID
# 格式：ep-20240601xxxxxx（你的接入点ID）
VOLCENGINE_MODEL_ID=ep-your-model-id-here

# ========== 通用配置（可选）==========

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 请求超时时间（秒）
TIMEOUT_SECONDS=900

# 温度参数（0-2）：控制输出随机性
TEMPERATURE=0.7

# 最大输出token数
MAX_COMPLETION_TOKENS=32768
