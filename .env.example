# 学术报告生成Agent - 环境变量配置示例
# 复制此文件为 .env 并填入你的配置
# 注意：.env 文件不应提交到Git仓库（已在.gitignore中）

# ========== COZE平台配置（必需） ==========

# COZE工作负载身份API密钥
# 获取方式：登录COZE平台 -> API密钥管理 -> 创建新密钥
COZE_WORKLOAD_IDENTITY_API_KEY=your_coze_api_key_here

# COZE集成模型基础URL
# 通常不需要修改，除非使用私有部署
COZE_INTEGRATION_MODEL_BASE_URL=https://api.coze.cn

# ========== 日志配置（可选） ==========

# 日志级别：DEBUG, INFO, WARNING, ERROR
# DEBUG: 显示所有日志
# INFO: 显示一般信息（默认）
# WARNING: 只显示警告和错误
# ERROR: 只显示错误
LOG_LEVEL=INFO

# ========== 超时配置（可选） ==========

# 请求超时时间（秒）
TIMEOUT_SECONDS=900

# ========== 开发配置（可选） ==========

# 是否启用调试模式
# DEBUG=true

# ========== 其他配置 ==========

# 项目根目录（通常不需要修改）
# COZE_WORKSPACE_PATH=/path/to/academic-report-agent
